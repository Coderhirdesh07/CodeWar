# ==========================================
# Dependencies
# ==========================================
node_modules/
dist/
build/
.npm/
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Individual service-level dependencies (Monorepo fallback)
services/**/node_modules/
services/**/dist/
services/**/build/

# ==========================================
# Environment Variables & Secrets (CRITICAL)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
services/**/.env

# ==========================================
# Docker & Database Local Storage
# ==========================================
# If you persist your MongoDB or Redis data locally using volumes
.docker-data/
mongo-data/
redis-data/
rabbitmq-data/

# ==========================================
# Editor & OS Specific Files
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# Code Execution Temporary Files
# ==========================================
# In case your worker server generates local temporary files/folders 
# when running user code before passing them to Docker.
services/worker-server/src/executors/temp/*
!services/worker-server/src/executors/temp/.gitkeep